    "    \"\"\"Usage\n",
    "    # viewer = napari.view_image(dic_dataset.to_dask(), name=\"dic_image\", cache=True)\n",
    "    # shape_layer = NapariVisualizer.viz_trajectories(traj_collection, viewer, contour_sample_num=20)\n",
